# CCD Orphanage Portal — environment variables
# Copy to .env and fill in values

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Local: postgres://...@localhost:5433/orphanage_db
# Production: use Managed PostgreSQL connection string from DigitalOcean
DATABASE_URL=postgres://orphanage_user:orphanage_pass@localhost:5433/orphanage_db

# Redis / Celery
# Local: redis://localhost:6379/0
# Production: redis://... (App droplet Redis or Upstash/DO Managed Redis)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# DO Spaces (media storage) — production only
# Set USE_SPACES=true and fill below to use DO Spaces. Leave empty for local filesystem.
USE_SPACES=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=lon1
AWS_S3_ENDPOINT_URL=https://lon1.digitaloceanspaces.com

# Twilio (WhatsApp webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_WEBHOOK_TOKEN=

# Telegram Bot (expense logging) — get token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth2 (admin SSO) — from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Africa's Talking (SMS confirmation) — optional
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
