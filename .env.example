# CCD Orphanage Portal — environment variables
# Copy to .env and fill in values

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Local: postgres://...@localhost:5433/orphanage_db
# Production: use Managed PostgreSQL connection string from DigitalOcean
DATABASE_URL=postgres://orphanage_user:orphanage_pass@localhost:5433/orphanage_db

# Redis / Celery
# Local: redis://localhost:6379/0
# Production: redis://... (App droplet Redis or Upstash/DO Managed Redis)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# DO Spaces (media storage) — production only
# Set USE_SPACES=true and fill below to use DO Spaces. Leave empty for local filesystem.
USE_SPACES=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=lon1
AWS_S3_ENDPOINT_URL=https://lon1.digitaloceanspaces.com

# WhatsApp Cloud API (Meta direct — see docs/WHATSAPP_SETUP_GUIDE.md)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot (expense logging) — get token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth2 (admin SSO via django-google-sso) — from Google Cloud Console
# Callback URL: https://your-domain.com/google_sso/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_SSO_PROJECT_ID=

# Africa's Talking (SMS confirmation) — optional
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=

# Exchange Rate API (exchangerate-api.com) — free tier, 1500 req/month
# Sign up at https://www.exchangerate-api.com/ (no credit card needed)
EXCHANGE_RATE_API_KEY=
