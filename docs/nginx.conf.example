# CCD Orphanage Portal — Nginx Configuration
#
# Copy to /etc/nginx/sites-available/orphanages and symlink to sites-enabled:
#   sudo cp docs/nginx.conf.example /etc/nginx/sites-available/orphanages
#   sudo ln -sf /etc/nginx/sites-available/orphanages /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# SSL is managed by Certbot. After initial setup run:
#   sudo certbot --nginx -d orphanages.ccdawah.org

server {
    server_name orphanages.ccdawah.org;
    client_max_body_size 20M;

    # Static files — served directly by nginx (fast, no Python involved)
    # Requires: python manage.py collectstatic --noinput
    location /static/ {
        alias /opt/orphanage/Orphanages/backend/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Media files (only needed if NOT using DO Spaces)
    location /media/ {
        alias /opt/orphanage/Orphanages/backend/media/;
        expires 7d;
        access_log off;
    }

    # Favicon
    location = /favicon.ico {
        access_log off;
        log_not_found off;
    }

    # Everything else → Gunicorn via Unix socket
    # Note: proxy_params already includes X-Forwarded-Proto — do NOT add it again
    # or the header will be duplicated ("https, https"), breaking OAuth redirect URIs.
    location / {
        include proxy_params;
        proxy_pass http://unix:/opt/orphanage/Orphanages/backend/gunicorn.sock;

        # Timeouts: must exceed Gunicorn's --timeout (120s) to avoid premature 502
        proxy_connect_timeout 10s;
        proxy_send_timeout 130s;
        proxy_read_timeout 130s;

        # Buffering: prevent 502 on large responses (PDF reports, dashboard data)
        proxy_buffering on;
        proxy_buffer_size 16k;
        proxy_buffers 8 16k;
        proxy_busy_buffers_size 32k;
    }

    listen 80;
    listen [::]:80;

    # After initial setup, run Certbot to add SSL:
    #   sudo certbot --nginx -d orphanages.ccdawah.org
    # Certbot will automatically:
    #   - Add ssl_certificate / ssl_certificate_key directives
    #   - Change listen to 443 ssl
    #   - Create an HTTP→HTTPS redirect server block
}
